default_platform(:ios)

platform :ios do
  desc "Run Flutter checks without uploading a build"
  lane :verify do
    Dir.chdir("..") do
      sh("flutter pub get")
      sh("flutter analyze")
      sh("flutter test")
    end
  end

  desc "Push a new beta build to TestFlight"
  lane :beta do
    increment_build_number(xcodeproj: "Runner.xcodeproj")
    build_app(
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.jonghwansong.slottapp" => "SlotApp_Distribution_Profile"
        }
      }
    )

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH")
    )

    upload_to_testflight(
      api_key: api_key
    )
  end
end
