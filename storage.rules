rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /assets/video/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /group_post_videos/{groupId}/{fileName} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && firestore.get(
          /databases/(default)/documents/group/$(groupId)
        ).data.memberIds.hasAny([request.auth.uid]);

      allow delete: if request.auth != null
        && firestore.get(
          /databases/(default)/documents/group/$(groupId)
        ).data.ownerId == request.auth.uid;
    }

    match /user_profile/{fileName} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null
        && fileName == request.auth.uid + '.jpg';
    }
  }
}
